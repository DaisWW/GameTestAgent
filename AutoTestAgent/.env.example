# ============================================================
# AutoTestAgent 配置模板
# 复制此文件为 .env 并填写对应的值
# ============================================================

# ── Vision Provider ─────────────────────────────────────────
# 可选值: omni_v2 | grounding_dino | mock
VISION_TYPE=omni_v2

# omni_v2 服务地址（运行 python models/omni/omniparser.py 启动）
OMNI_ENDPOINT=http://127.0.0.1:7861
OMNI_TIMEOUT=30

# ── LLM Provider ────────────────────────────────────────────
# 可选值: openai | anthropic | google | sequential
# sequential = 不调用任何 LLM，按元素 ID 顺序遍历点击（无需 API Key）
# openai 兼容 Qwen / DeepSeek / Moonshot / 本地 Ollama 等所有 OpenAI-format API
LLM_PROVIDER=sequential

# 通用 LLM 参数
LLM_API_KEY=sk-your-api-key-here
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1
LLM_TEMPLATE_KEY=default

# ── Qwen-VL（阿里云 DashScope，默认）───────────────────────
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-vl-max

# ── 切换到 DeepSeek-VL2（OpenAI 兼容，只改下面两行）────────
# LLM_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-vl2

# ── 切换到 Claude（需 pip install langchain-anthropic）──────
# LLM_PROVIDER=anthropic
# LLM_API_BASE=
# LLM_MODEL=claude-3-5-sonnet-20241022

# ── 切换到 Gemini（需 pip install langchain-google-genai）───
# LLM_PROVIDER=google
# LLM_API_BASE=
# LLM_MODEL=gemini-1.5-pro

# ── 切换到本地 Ollama（无需 API Key）────────────────────────
# LLM_PROVIDER=openai
# LLM_API_KEY=dummy
# LLM_API_BASE=http://localhost:11434/v1
# LLM_MODEL=llava:13b

# ── OmniParser 参数 ─────────────────────────────────────────
OMNI_IMGSZ=1280   # YOLO 输入分辨率（越大检出越小的元素，但推理更慢）
# OMNI_USE_PADDLEOCR=true  # 启用 PaddleOCR（中文识别更优，Windows OneDNN 下可能崩溃）

# ── Grounding DINO 参数（VISION_TYPE=grounding_dino 时生效）──
# 无需启动服务，模型在进程内加载（首次运行自动下载 ~700MB）
# 运行 python models/grounding_dino/grounding_dino.py 可预下载模型
# GDINO_MODEL=IDEA-Research/grounding-dino-tiny
# GDINO_TEXT_PROMPT=button . icon . close . back . text . input .
# GDINO_BOX_THRESHOLD=0.25
# GDINO_TEXT_THRESHOLD=0.25

# ── Agent 循环参数 ───────────────────────────────────────────
MAX_STEPS=600
STEP_DELAY=1.0

# ── ADB 设备 ────────────────────────────────────────────────
# 多设备时指定序列号，单设备留空即可
ADB_SERIAL=

# ── 游戏配置 ────────────────────────────────────────────────
GAME_PACKAGE=com.xjbkw.snow
GAME_ACTIVITY=com.unity3d.player.UnityPlayerActivity
GAME_LAUNCH_WAIT=15.0

# ── 输出 ────────────────────────────────────────────────────
# 数据目录自动按包名隔离：data/<GAME_PACKAGE>/
# 如需自定义路径可手动填写 OUTPUT_DIR，否则留空
OUTPUT_DIR=
SAVE_SCREENSHOTS=true
# 录屏：每次 run 自动录制设备屏幕，结束后保存 rec_NNNN.mp4 到 runs/<run_id>/
# 注意：需要设备支持 screenrecord（Android 4.4+），视频文件较大
SCREEN_RECORD=true

# ── Bug 检测器开关 ────────────────────────────────────────────
# 设为 false 可禁用对应维度的检测
CHECK_CRASH=true
CHECK_LAYOUT=true
CHECK_VISUAL=true
CHECK_FREEZE=true
CHECK_FUNCTIONAL=true
CHECK_CONTENT=true
